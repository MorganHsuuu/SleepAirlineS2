# Notion（Vercel 必填：API Key；父頁面選填，有預設值）
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=388a7f1b413c8015824ff6fb8bc1d65b

# 選填：若已手動建表可指定，否則程式會在父頁面自動尋找或建立 Dashboard
# NOTION_DASHBOARD_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 選填：降落風景圖資料庫（Sleep Airline Landing Scenery），未設定則在父頁面自動建立
# NOTION_LANDSCAPE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI（選填，機長廣播文字 + 語音 + 降落風景生圖）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=onyx
