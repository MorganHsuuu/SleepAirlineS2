# ── Notion（workshop：全部寫入主辦共用總表）────────────────
# 向主辦索取下列三項，貼到 Vercel → Settings → Environment Variables
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DASHBOARD_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_LANDSCAPE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 資料模式（選填）
# preview — 不寫 Notion，fork 改 UI 用（Vercel 不設 NOTION_API_KEY 時自動 preview）
# live    — 寫入主庫（有 NOTION_API_KEY 時預設 live）
# SLEEP_AIRLINE_DATA_MODE=live

# 學生請勿設定 NOTION_PARENT_PAGE_ID（避免指到錯誤頁面）。
# 以下僅主辦自用，勿分發給學員：
# NOTION_PARENT_PAGE_ID=388a7f1b413c8015824ff6fb8bc1d65b
# NOTION_ALLOW_SCHEMA_WRITE=true   # 僅主辦首次建主庫時短暫開啟

# OpenAI（選填，機長廣播文字 + 語音 + 降落風景生圖）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=onyx
